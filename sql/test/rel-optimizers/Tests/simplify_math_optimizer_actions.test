# Test simplify_math optimizer actions using EXPLAIN SHOW DETAILS
# Validates that the optimizer actually makes changes for each simplification rule
# by checking the action count reported in the optimizer run statistics.
# Uses the new optimizer_actions filter from testing/explain.py

statement ok
CREATE TABLE nums (id int PRIMARY KEY, a int, b int, c int, d int)

statement ok
INSERT INTO nums VALUES (1, 5, 10, 3, 2), (2, 0, 7, 0, 1), (3, 1, 0, 4, 1), (4, 2, 3, 5, 0), (5, 0, 0, 0, 0)

# =======================================
# MULTIPLICATION
# =======================================

# a * 1 = a
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT a * 1 FROM nums
----
simplify_math 1

# 1 * a = a
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT 1 * a FROM nums
----
simplify_math 1

# a * 0 = 0
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT a * 0 FROM nums
----
simplify_math 1

# 0 * a = 0
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT 0 * a FROM nums
----
simplify_math 1

# =======================================
# ADDITION
# =======================================

# a + 0 = a
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT a + 0 FROM nums
----
simplify_math 1

# 0 + a = a
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT 0 + a FROM nums
----
simplify_math 1

# =======================================
# SUBTRACTION
# =======================================

# a - 0 = a
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT a - 0 FROM nums
----
simplify_math 1

# a - a = 0
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT a - a FROM nums
----
simplify_math 1

# =======================================
# DIVISION
# =======================================

# a / 1 = a
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT a / 1 FROM nums
----
simplify_math 1

# 0 / a = 0
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT 0 / a FROM nums
----
simplify_math 1

# =======================================
# NEGATION
# =======================================

# -0 = 0
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT -0 FROM nums WHERE id = 1
----
simplify_math 1

# =======================================
# COMBINED EXPRESSIONS
# =======================================

# (a * 1) + 0 = a  (one simplification pass)
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT (a * 1) + 0 FROM nums
----
simplify_math 2

# (a / 1) + 0 = a
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT (a / 1) + 0 FROM nums
----
simplify_math 2

# (a - a) + b = b
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT (a - a) + b FROM nums
----
simplify_math 2

# (0 / a) + b = b
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT (0 / a) + b FROM nums
----
simplify_math 2

# (a * 0) + b = b
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT (a * 0) + b FROM nums
----
simplify_math 2

# =======================================
# NULL HANDLING (no simplification)
# =======================================

# NULL * 0 -> NULL (NULL semantics, no simplification)
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT NULL * 0
----

# NULL + 0 -> NULL
query T python .explain.optimizer_actions
EXPLAIN SHOW ALL DETAILS SELECT NULL + 0
----

# =======================================
# CLEANUP
# =======================================

statement ok
DROP TABLE nums
