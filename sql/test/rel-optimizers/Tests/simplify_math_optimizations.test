# COMBINED EXPRESSIONS
# =======================================

# Test: (a * 1) + 0 = a
query II
SELECT id, (a * 1) + 0 FROM nums WHERE a <> 0
----
1
5
3
1
4
2

# Test: (a + 0) * 1 = a
query II
SELECT id, (a + 0) * 1 FROM nums WHERE a <> 0
----
1
5
3
1
4
2

# Test: (a / 1) + 0 = a
query II
SELECT id, (a / 1) + 0 FROM nums WHERE a <> 0
----
1
5
3
1
4
2

# Test: power(a, 1) + 0 = a
query II
SELECT id, power(a, 1) + 0 FROM nums WHERE a <> 0
----
1
5
3
1
4
2

# Test: -(-(a + 0)) = a
query II
SELECT id, -(-(a + 0)) FROM nums WHERE a <> 0
----
1
5
3
1
4
