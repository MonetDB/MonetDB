# Test: (a - a) + b = 0 + b = b
query II
SELECT id, (a - a) + b FROM nums WHERE b <> 0
----
1
10
2
7
4
3

# Test: (0 / a) + b = 0 + b = b
query II
SELECT id, (0 / b) + b FROM nums WHERE b <> 0
----
1
10
2
7
4
3

# =======================================
# NULL HANDLING (no simplification when NULL semantics)
# =======================================

# Test: NULL * 0 -> NULL (NULL semantics, no simplification)
query I
SELECT NULL * 0
----
NULL

# Test: 0 * NULL -> NULL (NULL semantics, no simplification)
query I
SELECT 0 * NULL
----
NULL

# Test: NULL + 0 -> NULL
query I
SELECT NULL + 0
----
NULL

# Test: NULL - 0 -> NULL
query I
SELECT NULL - 0
----
NULL

# Test: NULL / 1 -> NULL
query I
SELECT NULL / 1
----
NULL

# Test: power(NULL, 0) -> NULL
query I
SELECT power(NULL, 0)
----
NULL

# Test: -NULL -> NULL
query I
SELECT -NULL
----
NULL

# =======================================
# EDGE CASES
# =======================================

# Test: (a * 0) + b = 0 + b = b
query II
SELECT id, (a * 0) + b FROM nums WHERE a <> 0 AND b <> 0
----
1
10
4
3

# Test: (a + 0) - 0 = a
query II
SELECT id, (a + 0) - 0 FROM nums WHERE a <> 0
----
1
5
3
1
4
2

# Test: (a / 1) * 1 = a
query II
