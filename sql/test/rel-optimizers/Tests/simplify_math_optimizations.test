----
1
5
3
1
4
2

# Test: power(a, 1) * a = a * a = a^2
query II
SELECT id, power(a, 1) * a FROM nums WHERE a = 2
----
4
4

# Test: a^1 + 0 = a (combined power + add simplification)
query II
SELECT id, power(a, 1) + 0 FROM nums WHERE a <> 0
----
1
5
3
1
4
2

# Test: -(-(a + 0)) = a (combined double negation + add)
query II
SELECT id, -(-(a + 0)) FROM nums WHERE a <> 0
----
1
5
3
1
4
2

# Test: (a - a) + b = 0 + b = b (combined)
query II
SELECT id, (a - a) + b FROM nums WHERE b <> 0
----
1
10
2
7
4
3

# Test: (0 / a) + b = 0 + b = b (combined)
query II
SELECT id, (0 / b) + b FROM nums WHERE b <> 0
