statement ok
CREATE TABLE decs (id int PRIMARY KEY, d DECIMAL(10,2))

statement ok
INSERT INTO decs VALUES (1, 5), (2, 0), (3, 1)

# Test: decimal a * 1 = a (optimizer simplifies to a, output as integer)
query II
SELECT id, d * 1.0 FROM decs WHERE d <> 0
----
1
5
3
1

# Test: decimal a / 1 = a
query II
SELECT id, d / 1.0 FROM decs WHERE d <> 0
----
1
5
3
1

# Test: decimal a / a = 1
query II
SELECT id, d / d FROM decs WHERE d <> 0
----
1
1
3
1

# Test: decimal a + 0 = a
query II
SELECT id, d + 0.0 FROM decs
----
1
5
2
0
3
1

# Test: decimal a - 0 = a
query II
SELECT id, d - 0.0 FROM decs
----
1
5
2
0
3
1

