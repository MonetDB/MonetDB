#-- mutated: should behave equivalently here, but deletes no rows in MonetDB
statement ok rowcount 2
DELETE FROM bug_t2
WHERE EXISTS (
  SELECT *
  FROM (
    SELECT c13, c13 + INTERVAL '13' MONTH + INTERVAL '19' DAY
    FROM bug_t2
    EXCEPT
