#-- original: deletes both rows
statement ok rowcount 2
DELETE FROM bug_t2
WHERE EXISTS (
  SELECT *
  FROM (
    SELECT c13, c13 + INTERVAL '13' MONTH + INTERVAL '19' DAY
    FROM bug_t2
    EXCEPT
    SELECT k, k2
    FROM (
      SELECT c5 AS k, c5 AS k2 FROM bug_t3
      UNION
      SELECT c13 AS k, c13 AS k2 FROM bug_t2
    ) AS s
  ) AS q
  WHERE q.c13 = q.c13
)

query I
SELECT COUNT(*) AS remaining_after_original FROM bug_t2
