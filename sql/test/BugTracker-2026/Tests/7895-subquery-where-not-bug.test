query I nosort
select count(*)
from
  orders as ref_0
----
5

query I nosort
select count(*)
from
  orders as ref_0
where (false AND nullif(case when ref_0.id is not NULL then true else true end, false))
----
0

query I nosort
select count(*)
from
  orders as ref_0
where (not (false AND nullif(case when ref_0.id is not NULL then true else true end, false)))
----
5

query I nosort
select (
select count(*)
from
  orders as ref_0
where (false AND nullif(case when ref_0.id is not NULL then true else true end, false))
) + (
select count(*)
from
  orders as ref_0
where (not (false AND nullif(case when ref_0.id is not NULL then true else true end, false)))
) + (
select count(*)
from
  orders as ref_0
where ((false AND nullif(case when ref_0.id is not NULL then true else true end, false)) is null)
)
----
5

statement ok
DROP TABLE orders

