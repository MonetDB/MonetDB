-- original query
statement error types tinyint(1,0) and timestamp(7,0) are not equal
SELECT v
FROM (
  SELECT p, v, LAG(dt, 1) OVER (PARTITION BY p ORDER BY o ASC) AS wa
  FROM t_bug16
) x
WHERE wa >= 1
ORDER BY v

-- explicit NULL default
statement error types tinyint(1,0) and timestamp(7,0) are not equal
SELECT v
FROM (
  SELECT p, v, LAG(dt, 1, NULL) OVER (PARTITION BY p ORDER BY o ASC) AS wa
  FROM t_bug16
) x
WHERE wa >= 1
ORDER BY v

