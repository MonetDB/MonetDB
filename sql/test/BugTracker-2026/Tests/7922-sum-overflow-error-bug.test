statement ok
CREATE TABLE t_bug12 (
  id INT PRIMARY KEY,
  p SMALLINT NOT NULL,
  ot INT NOT NULL,
  v INT NOT NULL,
  vf DOUBLE PRECISION NOT NULL
)

statement ok
CREATE TABLE t_bug12_aux (
  id INT PRIMARY KEY,
  ref_id INT NOT NULL
)

