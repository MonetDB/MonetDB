-- equivalent rewrite
query II nosort
SELECT p, v
FROM (
  SELECT s.p, s.v, s.ot, s.vf
  FROM t_bug12 AS s
  LEFT JOIN t_bug12_aux AS a ON a.ref_id = s.id
) AS t1
WHERE (
  SELECT SUM(t2.vf)
  FROM (
    SELECT s.p, s.v, s.ot, s.vf
    FROM t_bug12 AS s
    LEFT JOIN t_bug12_aux AS a ON a.ref_id = s.id
  ) AS t2
  WHERE t2.p = t1.p
    AND t2.ot >= t1.ot - 5
    AND t2.ot <= t1.ot + 5
) >= 2
ORDER BY p, v
----
-11
-202
