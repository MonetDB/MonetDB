-202
-11
976
-9
-805
-9
-805
-9
960

-- the sum(t_bug12.vf) needs to add: -1e308 + -1e308 + 1e308, which apparently fails with overflow in calculation error
query R nosort
SELECT -1e308 + -1e308 + 1e308 as sum
----
-.000

-- if we add precedence MonetDB can compute without overflow in calculation error
query R nosort
SELECT -1e308 + (-1e308 + 1e308) as sum
----
-.000


-- Note: without the "WHERE wa >= 2" part it does not return: 22003!overflow in calculation.
query II nosort
SELECT p, v
FROM (
  SELECT s.p,
         s.v,
         SUM(s.vf) OVER (
           PARTITION BY s.p
           ORDER BY s.ot ASC
           RANGE BETWEEN 5 PRECEDING AND 5 FOLLOWING
         ) AS wa
  FROM t_bug12 AS s
  LEFT JOIN t_bug12_aux AS a ON a.ref_id = s.id
) x
ORDER BY p, v
