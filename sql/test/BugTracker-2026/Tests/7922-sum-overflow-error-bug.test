-- original window query
-- MonetDB returns: 22003!overflow in calculation. but other RDBMS do not.
-- the sum(t_bug12.vf) needs to add: -1e308 + -1e308 + 1e308, which apparently fails with overflow in calculation error, see below.
query II nosort
SELECT p, v
FROM (
  SELECT s.p,
         s.v,
         SUM(s.vf) OVER (
           PARTITION BY s.p
           ORDER BY s.ot ASC
           RANGE BETWEEN 5 PRECEDING AND 5 FOLLOWING
         ) AS wa
  FROM t_bug12 AS s
  LEFT JOIN t_bug12_aux AS a ON a.ref_id = s.id
) x
WHERE wa >= 2
ORDER BY p, v
----
-11
-202
