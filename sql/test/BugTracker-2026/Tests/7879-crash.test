INSERT INTO orders VALUES
(1, 1, 100.00, 'paid',    '2022-02-01 09:00:00'),
(2, 1, 200.50, 'shipped', '2022-02-02 10:00:00'),
(3, 2, NULL,   'failed',  '2022-02-03 11:00:00'),
(4, 3, 50.00,  'paid',    '2022-02-04 12:00:00'),
(5, 5, 999.99, 'paid',    '2022-02-05 13:00:00')

query TITI rowsort
SELECT
    (SELECT created_at FROM orders LIMIT 1 OFFSET 5) AS c0,
    ref_2.id AS c1,
    MAX(
        UPPER(
            REPLACE(
                'K',
                CASE WHEN TRUE AND FALSE THEN 'onw07j' ELSE 'Er9U' END,
                COALESCE('zGR', '37')
            )
        )
    ) OVER (PARTITION BY ref_2.likes ORDER BY ref_2.user_id, ref_2.likes) AS c2,
    ref_2.user_id AS c3
FROM (
    SELECT subq_0.c0 AS c0
    FROM orders AS ref_0,
         LATERAL (
             SELECT ref_0.id AS c0
             FROM orders AS ref_1
             WHERE TRUE
             LIMIT 61
         ) AS subq_0
    WHERE FALSE
    LIMIT 134
) AS subq_1
LEFT JOIN posts AS ref_2
    ON TRUE
WHERE ref_2.user_id <= ref_2.views
