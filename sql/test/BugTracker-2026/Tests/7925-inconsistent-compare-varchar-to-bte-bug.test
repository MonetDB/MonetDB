statement ok
CREATE TABLE t_bug15 (
  id INT,
  p INT,
  o INT,
  vc VARCHAR(32),
  v INT,
  PRIMARY KEY (id)
)

statement ok rowcount 4
INSERT INTO t_bug15 VALUES
  (1, -26, 30, NULL, 354),
  (2, -26, 20, 'alpha', 325),
  (3, -26, 10, 'beta', 376),
  (4, -26, 0, 'gamma', -74)

-- original window query
query I nosort
SELECT v
FROM (
  SELECT v,
         NTH_VALUE(vc, 2) OVER (
           PARTITION BY p
           ORDER BY o DESC
           ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
         ) AS wa
  FROM t_bug15
) x
WHERE wa >= 1
  AND wa < 3
ORDER BY v
----

-- equivalent rewrite
-- MonetDB fails with error: 22018!conversion of string to type bte failed.
query I nosort
SELECT t1.v
FROM t_bug15 AS t1
WHERE (
  SELECT t2.vc
  FROM t_bug15 AS t2
  WHERE t2.p = t1.p
  ORDER BY t2.o DESC
  LIMIT 1 OFFSET 1
) >= 1
  AND (
    SELECT t2.vc
    FROM t_bug15 AS t2
    WHERE t2.p = t1.p
    ORDER BY t2.o DESC
    LIMIT 1 OFFSET 1
  ) < 3
ORDER BY t1.v
----

-- equivalent rewrite, but with manually changed comparisons against varchars
query I nosort
SELECT t1.v
FROM t_bug15 AS t1
WHERE (
  SELECT t2.vc
  FROM t_bug15 AS t2
  WHERE t2.p = t1.p
  ORDER BY t2.o DESC
  LIMIT 1 OFFSET 1
) >= '1'	-- changed
  AND (
    SELECT t2.vc
    FROM t_bug15 AS t2
    WHERE t2.p = t1.p
    ORDER BY t2.o DESC
    LIMIT 1 OFFSET 1
  ) < '3'	-- changed
ORDER BY t1.v
