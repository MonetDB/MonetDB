-- query without OR EXISTS () runs
query I rowsort
select  1
from posts as ref_0, comments as ref_3
right join comments as ref_4 on (39.23 = (select avg(id) from posts))
inner join (select  1 as c5 from users where (true) limit 98) as subq_0
on (subq_0.c5 != ref_3.post_id)
inner join orders as ref_7
on ref_3.post_id IS NOT NULL
----

