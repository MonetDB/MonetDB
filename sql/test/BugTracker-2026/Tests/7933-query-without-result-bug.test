query I nosort
SELECT COUNT(*)
FROM (
    SELECT
        STARTSWITH(
            SUBSTRING(
                CASE
                    WHEN (SELECT id FROM comments LIMIT 1 OFFSET 4) > 7
                    THEN 'h76pod'
                    ELSE 'z16o5'
                END,
                ref_0.id,
                ref_0.user_id
            ),
            CASE
                WHEN 's4' < 'tv17p' THEN 'u2'
                ELSE '9rdj6k'
            END
        ) AS c0
    FROM comments AS ref_0
    WHERE ref_0.user_id > ref_0.post_id
) AS subq_0,
     users AS ref_1
WHERE SPLITPART(
        CASE
            WHEN FALSE
            THEN SUBSTR(LPAD('hhqj', ref_1.id), 40)
            ELSE CASE
                    WHEN subq_0.c0 OR subq_0.c0
                    THEN 'w1'
                    ELSE '7n5'
                 END
        END,
        SPLITPART('mt0l', 'd2', ref_1.id),
        ref_1.id
      ) > CASE
            WHEN EXISTS (
                    SELECT
                        (SELECT VAR_POP(id) FROM comments) AS c0,
                        ref_1.status AS c1,
                        ref_2.post_id AS c2
                    FROM comments AS ref_2
                    WHERE subq_0.c0 IS NULL
                 )
            THEN 'fhq4p0'
            ELSE SUBSTRING(
                    CASE
                        WHEN '7v0f' <= 'rry' THEN 'j7'
                        ELSE 'g1tyj5'
                    END,
                    ref_1.age,
                    ref_1.age
                 )
         END
