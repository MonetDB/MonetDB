-- query with UNION ALL
query I rowsort
SELECT c1 FROM t3
WHERE c5 IN (
    SELECT c5 AS k
    FROM t3
    UNION
    SELECT k
    FROM (
        SELECT c13 AS k, c13 AS k2
        FROM t2
        EXCEPT
        SELECT k, TIMESTAMP '2014-04-20 20:56:07' AS k2
        FROM (
            SELECT c13 AS k, TIMESTAMP '2025-01-28 17:31:29' AS k2
            FROM t2
            UNION ALL
            SELECT c13 AS k, c13 AS k2
            FROM t2
        ) s
        WHERE k >= TIMESTAMP '2014-04-20 20:56:07'
    ) e
)
----
1
3

-- same query with INTERSECT instead of UNION ALL
-- produces on Dec2025-SP2 v11.55.5 (hg id: 691e862e16ce+): sql/backends/monet5/rel_bin.c:1909: exp_bin: Assertion `s' failed.
query I rowsort
SELECT c1 FROM t3
WHERE c5 IN (
    SELECT c5 AS k
    FROM t3
    UNION
    SELECT k
    FROM (
        SELECT c13 AS k, c13 AS k2
        FROM t2
        EXCEPT
        SELECT k, TIMESTAMP '2014-04-20 20:56:07' AS k2
        FROM (
            SELECT c13 AS k, TIMESTAMP '2025-01-28 17:31:29' AS k2
            FROM t2
            INTERSECT
            SELECT c13 AS k, c13 AS k2
            FROM t2
        ) s
        WHERE k >= TIMESTAMP '2014-04-20 20:56:07'
    ) e
)
----
1
3

