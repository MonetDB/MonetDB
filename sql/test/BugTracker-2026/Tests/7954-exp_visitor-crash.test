-- adapted query without the last 'NOT IN (SELECT ...)' part works.
query T nosort
SELECT COUNT ( * ) = 0 AS x
  FROM ( SELECT CAST( 55 AS NUMERIC ) AS x
           FROM ( SELECT 1 AS x ) AS x
         UNION
         SELECT 0 AS x GROUP BY ROLLUP ( x )
         UNION
         SELECT 3 AS x
       )
 WHERE levenshtein ( '\xf4\x8f\xbf\xbf' , 2 , 1 , 1 )
----
False

