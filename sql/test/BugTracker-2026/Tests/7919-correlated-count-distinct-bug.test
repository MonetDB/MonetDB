-- original window query
query I nosort
SELECT v
FROM (
  SELECT v, DENSE_RANK() OVER (PARTITION BY p ORDER BY ot DESC) AS rn
  FROM t_bug9
) x
WHERE rn IN (1, 3, 4)
ORDER BY v
