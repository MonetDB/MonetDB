-- equivalent rewrite
query I nosort
SELECT t1.v
FROM t_bug9 AS t1
WHERE (
  SELECT COUNT(DISTINCT t2.ot)
  FROM t_bug9 AS t2
  WHERE t2.p = t1.p
    AND t2.ot > t1.ot
) IN (0, 2, 3)
ORDER BY t1.v
