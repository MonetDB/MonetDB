-- mserver5: sql/backends/monet5/rel_bin.c:4959: rel2bin_select: Assertion `sql->session->status == -10' failed.
query IITTTTT rowsort
SELECT
    ref_0.age AS c0,
    (SELECT id FROM orders LIMIT 1 OFFSET 34) AS c1,
    ref_0.email AS c2,
    ref_0.username AS c4,
    ref_0.created_at AS c5,
    (SELECT created_at FROM users LIMIT 1 OFFSET 5) AS c6,
    COALESCE(subq_0.c6, ref_0.status) AS c7
FROM users AS ref_0
RIGHT JOIN (
    SELECT DISTINCT
        57 AS c2,
        ref_1.content AS c6
    FROM posts AS ref_1
    WHERE ref_1.rating IS NOT NULL
) AS subq_0
ON (
    EXISTS (
        SELECT 1
        FROM comments AS ref_2
        LEFT JOIN users AS ref_3
            ON ((ref_0.username IS NOT NULL) OR (subq_0.c2 IS NOT NULL))
        WHERE ref_3.created_at IS NOT NULL
    )
    AND (
        (SELECT var_samp(id) FROM posts) <= 89.71
        OR TRUE
    )
)
WHERE ref_0.score IS NULL
LIMIT 95
