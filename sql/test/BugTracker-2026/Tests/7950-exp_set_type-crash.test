-- query without the complex 'ORDER BY x IN ( SELECT ... ) ASC' part doesn't crash
query TR rowsort
SELECT nth_value ( ( EXISTS ( SELECT 1 WHERE x > 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 + 0.100000 * 0.100000 + 0.100000 AND ( x IS NULL OR x IS NULL )
                            )
                   ) IN ( ( SELECT FALSE
                          )
                        ) , 1 ) OVER ( )
 , LOG ( DISTINCT x )
  FROM ( SELECT CAST( NULL AS VARCHAR ) AS x
          UNION
         SELECT CAST( NULL AS VARCHAR ) AS x )
