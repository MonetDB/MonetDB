query RTR rowsort
SELECT x
 , nth_value ( 'bug' , 1 ) OVER ( RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW )
 , max ( x ) OVER ( ORDER BY x DESC RANGE BETWEEN CURRENT ROW AND 1 FOLLOWING )
  FROM ( SELECT sql_div ( 3.400000 , locate ( '5.6' , '0.1.2.3.5.4.5.6.8.5.6.8' , 7 ) ) AS x
       )
