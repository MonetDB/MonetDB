-- equivalent rewrite
query II nosort
SELECT p, v
FROM (
  SELECT p, v, o, vt
  FROM t_bug10
) AS t1
WHERE (
  SELECT top1.vt
  FROM (
    SELECT t2.vt AS vt
    FROM (
      SELECT p, v, o, vt
      FROM t_bug10
    ) AS t2
    WHERE t2.p = t1.p
    ORDER BY t2.o DESC
    LIMIT 1
  ) AS top1
) >= 1
ORDER BY p, v
