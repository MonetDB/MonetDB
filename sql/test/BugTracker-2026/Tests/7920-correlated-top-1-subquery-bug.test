-- original window query
query II nosort
SELECT p, v
FROM (
  SELECT p, v, FIRST_VALUE(vt) OVER (PARTITION BY p ORDER BY o DESC) AS wa
  FROM t_bug10
) x
WHERE wa >= 1
ORDER BY p, v
