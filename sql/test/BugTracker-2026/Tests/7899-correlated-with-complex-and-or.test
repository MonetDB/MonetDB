query I
select count(*)
from 
  users as ref_0
where (EXISTS (
  select 1
    from 
      comments as ref_1,
      lateral (select  
            ref_2.user_id as c0, 
            ref_2.amount as c1, 
            ref_0.username as c2
          from 
            orders as ref_2
          where (ref_2.user_id != ref_2.id) 
            and ((17.28 < 38.26) 
              or (ref_0.email is NULL))) as subq_0
    where 28.11 != 58.42))
----
5

query I
select sum(case when (EXISTS (
  select 1
    from 
      comments as ref_1,
      lateral (select  
            ref_2.user_id as c0, 
            ref_2.amount as c1, 
            ref_0.username as c2
          from 
            orders as ref_2
          where (ref_2.user_id != ref_2.id) 
            and ((17.28 < 38.26) 
              or (ref_0.email is NULL))) as subq_0
    where 28.11 != 58.42)) then 1 else 0 end + 0)
from 
  users as ref_0
----
5
