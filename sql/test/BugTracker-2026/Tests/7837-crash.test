query T
select
  nullif(subq_1.c0,
    null) as c0
from
  posts as ref_0,
  lateral (select
        ref_2.title as c0,
        ref_2.created_at as c1,
        ref_0.rating as c2,
        ref_2.rating as c3,
        ref_1.content as c4,
        subq_0.c0 as c5,
        77 as c6,
        case when EXISTS (
            select
                ref_9.user_id as c0,
                ref_4.created_at as c1,
                subq_0.c0 as c2,
                ref_1.id as c3
              from
                orders as ref_9
              where (select avg(id) from posts)
                   >= 69.10) then ref_2.created_at else (select created_at from orders limit 1 offset 2)
             end
           as c7
      from
        posts as ref_1
            inner join posts as ref_2
                inner join comments as ref_3
                on (ref_2.content is not NULL)
              inner join comments as ref_4
                inner join comments as ref_5
                on (ref_5.post_id <> ref_5.id)
              on (false)
            on ((select created_at from comments limit 1 offset 3)
                   is NULL)
          inner join orders as ref_6
          on (('c' <> 'tzD')
              or ((true)
                or (57 < (select id from orders limit 1 offset 5)
                    ))),
        lateral (select
              ref_2.created_at as c0
            from
              orders as ref_7
                inner join comments as ref_8
                on (true)
            where ref_0.likes < (select id from posts limit 1 offset 6)
            limit 181) as subq_0
      where 1.1111111 <= 1.1111111
      limit 106) as subq_1
where 99.97 = coalesce(case when coalesce(coalesce('L',
            'm'),
          'PLmA9') > coalesce('FYpEbd',
          case when (true)
              and (false) then 'Vy' else 'Zr' end
            ) then abs(
        case when true OR true then case when 'xVD' <> 'AiuU' then 12.38 else (select stddev_samp(id) from posts)
               end
             else 15.31 end
          ) else log(
        19.46) end
      ,
    (select var_samp(id) from comments)
      )
limit 140
----

query I
select 1
from posts ref_0,
lateral (
  select
    case
      when EXISTS ( select 1 from orders where (select avg(id) from posts) >= 69.10)
      then ref_1.created_at
      else (select created_at from orders limit 1)
    end as c7
  from posts ref_1
    inner join orders ref_6
      on 57 < (select id from orders limit 1),
  lateral (
    select ref_1.created_at
    from orders
    where ref_0.likes < (select id from posts limit 1)
    limit 1
  ) subq_0
) subq_1
