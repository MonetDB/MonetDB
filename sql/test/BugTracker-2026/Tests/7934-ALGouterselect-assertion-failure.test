query I nosort
SELECT count(*)
FROM orders AS ref_0
INNER JOIN (
    SELECT DISTINCT ref_1.user_id AS c0
    FROM comments ref_1
    WHERE coalesce('s1bem','3t46to')
          > CASE WHEN ref_1.content IS NULL THEN '0n7' ELSE 'pb' END
) subq_0
ON (
    coalesce(
        35.39,
        CASE
            WHEN EXISTS (
                SELECT 1
                FROM (
                    SELECT ref_0.created_at
                    FROM posts ref_2,
                         LATERAL (
                             SELECT subq_0.c0
                             FROM (
                                 SELECT ref_3.username
                                 FROM users ref_3
                                 WHERE 35.53 < (SELECT var_samp(id) FROM users)
                             ) subq_3
                             WHERE ref_0.user_id < 1
                         ) subq_4
                    WHERE FALSE
                ) subq_5
                WHERE 'jj' <> 'xyf6'
            )
            THEN 12.7
            ELSE (SELECT avg(id) FROM posts)
        END
    )
    <= (SELECT var_samp(id) FROM posts)
)
OR FALSE
----
0

-- same query but switched from 'orders INNER JOIN subquery on comments' to 'subquery on comments INNER JOIN orders'
-- monetdb5/modules/kernel/algebra.c:497: ALGouterselect: Assertion `g->tsorted' failed.
query I nosort
SELECT count(*)
FROM (
    SELECT DISTINCT ref_1.user_id AS c0
    FROM comments ref_1
    WHERE coalesce('s1bem','3t46to')
          > CASE WHEN ref_1.content IS NULL THEN '0n7' ELSE 'pb' END
) subq_0
INNER JOIN orders ref_0
ON (
    coalesce(
        35.39,
        CASE
            WHEN EXISTS (
                SELECT 1
                FROM (
                    SELECT ref_0.created_at
                    FROM posts ref_2,
                         LATERAL (
                             SELECT subq_0.c0
                             FROM (
                                 SELECT ref_3.username
                                 FROM users ref_3
                                 WHERE 35.53 < (SELECT var_samp(id) FROM users)
                             ) subq_3
                             WHERE ref_0.user_id < 1
                         ) subq_4
                    WHERE FALSE
                ) subq_5
                WHERE 'jj' <> 'xyf6'
            )
            THEN 12.7
            ELSE (SELECT avg(id) FROM posts)
        END
    )
    <= (SELECT var_samp(id) FROM posts)
)
OR FALSE
----
0

