-- adapted query without the last 'WHERE x NOT IN ( WITH RECURSIVE ...)' part works.
query T nosort
SELECT COUNT ( * ) = 0 AS x
  FROM ( SELECT 1 AS x
         UNION
         SELECT 0 AS x
         UNION
         SELECT 3 AS x )
