-- next query with commented out 'UNION SELECT nth_value()' part works
query II rowsort
SELECT DISTINCT x
 , CASE WHEN x > 12 THEN 1 WHEN x <= 0.080000 THEN 4 ELSE 0 END AS x
  FROM ( SELECT 1 , 3 , 3 FROM generate_series ( 42749 , 5 ) ) AS x
     , ( SELECT 10 AS x
          UNION
         SELECT 11 AS x
--        UNION
--       SELECT nth_value ( - 51 * - - 12 * - 27 * CASE WHEN NOT '_b_' IN ( - 69 , ( SUM ( DISTINCT CAST( NULL AS INTEGER ) ) ) + MAX ( - 6 ) + - COUNT ( * ) / - - ( 77 ) + 37 , 44 , - - 0 * 23 , - - 86 , '_b%' , 'abc' , ( SELECT 10 ) , FALSE ) THEN 'three' WHEN NOT - 21 / - 95 IS NOT NULL THEN 63 END , '1' ) OVER ( RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING )
          UNION
         SELECT 13 AS x
      )
----
10
0
11
0
13
1

-- test the crashing 'SELECT nth_value()' query independently
