-- sql/backends/monet5/rel_bin.c:3479: rel2bin_join: Assertion `sql->session->status == -10' failed.
query I nosort
SELECT 1
FROM (
    SELECT
        MAX(ref_2.age) OVER (
            PARTITION BY ref_1.amount
            ORDER BY ref_0.status, ref_2.created_at
        ) AS c0
    FROM users AS ref_0
    RIGHT JOIN orders AS ref_1
        ON ((SELECT STDDEV_POP(id) FROM posts) <= 29.14)
    INNER JOIN users AS ref_2
        ON (ref_1.id != ref_2.id)
    WHERE FALSE
) AS subq_0,
LATERAL (
    SELECT ref_3.id AS c8
    FROM comments AS ref_3,
         LATERAL (
            SELECT ref_6.user_id AS c0
            FROM users AS ref_4
            INNER JOIN posts AS ref_5
                RIGHT JOIN posts AS ref_6
                    ON ((SELECT STDDEV_SAMP(id) FROM users)
                        < (SELECT VAR_SAMP(id) FROM posts))
            ON TRUE
            WHERE ((SELECT email FROM users LIMIT 1 OFFSET 3) IS NULL)
              AND (subq_0.c0 <= ref_6.likes)
            LIMIT 153
         ) AS subq_1
    WHERE ref_3.user_id <> subq_0.c0
) AS subq_2
WHERE TRUE
  AND COALESCE(
        TRUE,
        COALESCE(
            CASE
                WHEN ((24.19 <= 12.11)
                      AND EXISTS (
                            SELECT 1
                            FROM posts AS ref_8,
                                 LATERAL (
                                    SELECT subq_0.c0 AS c1
                                    FROM orders AS ref_9
                                    WHERE TRUE
                                 ) AS subq_3
                            WHERE subq_3.c1 <> subq_2.c8
                            LIMIT 164
                        ))
                  OR (((77.7 = (SELECT AVG(id) FROM orders))
                       OR (subq_0.c0 IS NOT NULL)))
                THEN TRUE
                ELSE TRUE
            END,
            FALSE
        )
      )
