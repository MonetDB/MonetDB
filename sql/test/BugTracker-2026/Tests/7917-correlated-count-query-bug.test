-- original window query
query I rowsort
SELECT v
FROM (
SELECT v, RANK() OVER (PARTITION BY p ORDER BY o) AS rn
FROM t_bug7
) x
WHERE rn IN (1, 3)
ORDER BY v
----
101
102
201
202

-- equivalent rewrite
query I rowsort
SELECT t1.v
FROM t_bug7 AS t1
WHERE (
SELECT COUNT(*)
FROM t_bug7 AS t2
WHERE t2.p = t1.p
AND t2.o < t1.o
) IN (0, 2)
ORDER BY v
----
101
102
201
202

-- workaround query
query I rowsort
SELECT t1.v
FROM t_bug7 AS t1
WHERE CASE WHEN (
SELECT COUNT(*)
FROM t_bug7 AS t2
WHERE t2.p = t1.p
AND t2.o < t1.o
) IN (0, 2) THEN 1 ELSE 0 END = 1
ORDER BY v
----
101
102
201
202

