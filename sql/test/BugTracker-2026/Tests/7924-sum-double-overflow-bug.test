-- original window query
-- MonetDB fails with: 22003!overflow in calculation.
query II nosort
SELECT p, v
FROM (
  SELECT p, v,
         SUM(vf) OVER (
           PARTITION BY p
           ORDER BY od DESC
           ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
         ) AS wa
  FROM t_bug14
) x
WHERE wa >= 2
  AND v >= -178
ORDER BY p, v
