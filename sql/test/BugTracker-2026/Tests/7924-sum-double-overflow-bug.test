-- equivalent rewrite
-- MonetDB fails with: 22003!overflow in sum aggregate.
query II nosort
SELECT p, v
FROM (
  SELECT p, v, od, vf
  FROM t_bug14
) AS t1
WHERE (
  SELECT SUM(t2.vf)
  FROM (
    SELECT p, v, od, vf
    FROM t_bug14
  ) AS t2
  WHERE t2.p = t1.p
    AND NOT (t1.od > t2.od)
) >= 2
  AND v >= -178
ORDER BY p, v
