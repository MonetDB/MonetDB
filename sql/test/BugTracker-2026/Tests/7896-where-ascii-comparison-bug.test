query I nosort
SELECT COUNT(*)
    FROM (
        SELECT DISTINCT subq_1.c0 AS c0, subq_1.c1 AS c1, subq_1.c1 AS c2
        FROM orders AS ref_0
        LEFT JOIN (
            SELECT subq_0.c0 AS c0, ref_1.content AS c1, 72 AS c2
            FROM posts AS ref_1,
                 LATERAL (
                     SELECT ref_1.id AS c0
                     FROM comments AS ref_2
                     WHERE ref_2.is_spam IS NOT NULL
                 ) AS subq_0
            WHERE 90.39 <= 18.48
        ) AS subq_1 ON ref_0.id IS NULL
        WHERE rtrim('9m5a') < ltrim('r5')
    ) AS subq_2
----
1

query I nosort
SELECT COUNT(*)
    FROM (
        SELECT DISTINCT subq_1.c0 AS c0, subq_1.c1 AS c1, subq_1.c1 AS c2
        FROM orders AS ref_0
        LEFT JOIN (
            SELECT subq_0.c0 AS c0, ref_1.content AS c1, 72 AS c2
            FROM posts AS ref_1,
                 LATERAL (
                     SELECT ref_1.id AS c0
                     FROM comments AS ref_2
                     WHERE ref_2.is_spam IS NOT NULL
                 ) AS subq_0
            WHERE 90.39 <= 18.48
        ) AS subq_1 ON ref_0.id IS NULL
        WHERE rtrim('9m5a') < ltrim('r5')
    ) AS subq_2
    WHERE ascii(
        CASE WHEN (
            FALSE
            AND (
                ((SELECT stddev_pop(id) FROM users) <> 100.74
                 OR (
                     EXISTS (
                         SELECT 1
                         FROM comments AS ref_3,
                              LATERAL (
                                  SELECT subq_2.c1 AS c0
                                  FROM posts AS ref_6
                                  WHERE 'dfwhb' <> 'k6c'
                              ) AS subq_5
                         WHERE true
                     )
                 )
                )
            )
            AND subq_2.c2 IS NOT NULL
        ) THEN 'rsf' ELSE rtrim('jzm3') END
    ) <> (SELECT MIN(id) FROM orders)
----
1

