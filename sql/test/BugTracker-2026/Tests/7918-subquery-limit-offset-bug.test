statement ok
CREATE TABLE t_bug8 (
  id INT NOT NULL,
  p SMALLINT NOT NULL,
  o INT NOT NULL,
  ot INT NOT NULL,
  od DECIMAL(20, 10) NOT NULL,
  odt DECIMAL(20, 10) NOT NULL,
  os VARCHAR(128) NOT NULL,
  ost VARCHAR(128) NOT NULL,
  v INT NOT NULL DEFAULT 0 CHECK (v BETWEEN -1000 AND 1000),
  vn INT NULL,
  vb BIGINT NOT NULL,
  vt SMALLINT NOT NULL,
  vf DOUBLE PRECISION NOT NULL,
  vc VARCHAR(128) NULL,
  dt TIMESTAMP NOT NULL,
  PRIMARY KEY (id),
  UNIQUE (p, od)
)

