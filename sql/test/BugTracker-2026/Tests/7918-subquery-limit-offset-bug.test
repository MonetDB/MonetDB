-- original window query
query I nosort
SELECT v
FROM (
  SELECT v, ROW_NUMBER() OVER (PARTITION BY p ORDER BY od DESC) AS rn
  FROM t_bug8
) x
WHERE rn = 2
ORDER BY v
----
-270

-- equivalent rewrite
query I nosort
SELECT t1.v
FROM (
  SELECT p, v, od
  FROM t_bug8
) AS t1
WHERE t1.od = (
  SELECT nth.od
  FROM (
    SELECT t2.od AS od
    FROM (
      SELECT p, v, od
      FROM t_bug8
    ) AS t2
    WHERE t2.p = t1.p
    ORDER BY t2.od DESC
    LIMIT 1 OFFSET 1
  ) AS nth
)
ORDER BY t1.v
----
