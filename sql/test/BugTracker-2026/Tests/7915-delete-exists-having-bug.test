query I nosort
SELECT COUNT(*) FROM rt3_o
WHERE EXISTS (
  (SELECT rt2.ts AS k, rt2.ts AS k2 FROM rt2)
  EXCEPT
  (SELECT rt2.ts AS k, rt2.ts AS k2
   FROM rt2
   GROUP BY rt2.ts
   HAVING rt2.ts IS NULL)
)
----
1

-- ORIGINAL
statement ok rowcount 1
DELETE FROM rt3_o
WHERE EXISTS (
  (SELECT rt2.ts AS k, rt2.ts AS k2 FROM rt2)
  EXCEPT
  (SELECT rt2.ts AS k, rt2.ts AS k2
   FROM rt2
   GROUP BY rt2.ts
   HAVING rt2.ts IS NULL)
)

query I nosort
SELECT COUNT(*) FROM rt3_m
WHERE EXISTS (
  (SELECT rt2.ts AS k, rt2.ts AS k2 FROM rt2)
  EXCEPT
  (SELECT rt2.ts AS k, rt2.ts AS k2
   FROM rt2
   GROUP BY rt2.ts
   HAVING 1 = 0)
)
----
1

-- MUTATED
