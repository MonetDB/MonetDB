-- query with disabled  'ORDER BY , 71 + - AVG ( 0.100000 ) + 12 / - - COUNT ( * )'  part works
query IRI rowsort
SELECT a , b , c
  FROM ( SELECT 1 AS a , 2 AS b , 3 AS c
         UNION ALL
         SELECT 4 AS a , NULL AS b , 6 AS c
         UNION ALL
         SELECT 7 AS a , 1.770000 AS b , 9 AS c ) AS t
 GROUP BY ROLLUP ( a , b ) , ROLLUP ( a , c )
 ORDER BY a
--      , 71 + - AVG ( 0.100000 ) + 12 / - - COUNT ( * )
        , c
 LIMIT 99
