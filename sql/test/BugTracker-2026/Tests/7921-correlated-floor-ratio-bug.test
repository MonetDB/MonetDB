-- rewritten window query
-- bucket = FLOOR(count_before / 2) + 1
query I nosort
SELECT t1.v
FROM t_bug11 AS t1
WHERE FLOOR((
  SELECT COUNT(*)
  FROM t_bug11 AS t2
  WHERE t2.p = t1.p
    AND t2.od < t1.od
) / 2) + 1 IN (1, 3, 4, 5)
ORDER BY t1.v
