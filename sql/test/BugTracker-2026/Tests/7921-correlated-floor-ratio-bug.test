-- original window query
query I nosort
SELECT v
FROM (
  SELECT v, NTILE(5) OVER (PARTITION BY p ORDER BY od ASC) AS rn
  FROM t_bug11
) x
WHERE rn IN (1, 3, 4, 5)
ORDER BY v
