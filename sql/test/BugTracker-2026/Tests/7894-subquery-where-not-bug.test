query I nosort
select (
select count(*)
from
  (select ref_0.user_id as c3
        from
          comments as ref_0
        where lpad('o', ref_0.id) <> 'kye') as subq_0
    right join users as ref_2
    on (ref_2.id < subq_0.c3)
where (false AND case when ref_2.score is NULL then case when 84.68 != sys.ms_round(
          (select stddev_pop(id) from orders),
          ref_2.id,
          0) then true else false end
       else false end
    )
) + (
select count(*)
from
  (select ref_0.user_id as c3
        from
          comments as ref_0
        where lpad('o', ref_0.id) <> 'kye') as subq_0
    right join users as ref_2
    on (ref_2.id < subq_0.c3)
where (not (false AND case when ref_2.score is NULL then case when 84.68 != sys.ms_round(
          (select stddev_pop(id) from orders),
          ref_2.id,
          0) then true else false end
       else false end
    ))
) + (
select count(*)
from
  (select ref_0.user_id as c3
        from
          comments as ref_0
        where lpad('o', ref_0.id) <> 'kye') as subq_0
    right join users as ref_2
    on (ref_2.id < subq_0.c3)
where ((false AND case when ref_2.score is NULL then case when 84.68 != sys.ms_round(
          (select stddev_pop(id) from orders),
          ref_2.id,
          0) then true else false end
       else false end
    ) is null)
)
