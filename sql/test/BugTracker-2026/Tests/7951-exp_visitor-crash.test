-- query with the 'HAVING NOT - - ( EXISTS ( SELECT 1 ) ) = ANY (...)' part disabled, doesn't crash
query T rowsort
SELECT COUNT ( * ) = 0 AS x
 FROM ( SELECT CAST( 55 AS NUMERIC ) AS x
          FROM ( SELECT 1 AS x ) AS x
        UNION
        SELECT 0 AS x GROUP BY ROLLUP ( x )
        UNION SELECT 3 AS x )
 WHERE levenshtein ( '\xf4\x8f\xbf\xbf' , 2 , 1 , 1 ) NOT
  IN (
      SELECT right_shift ( 8 , 2 )
       GROUP BY x
       HAVING avg ( DISTINCT x ) < ROUND ( x , - COUNT ( * ) )
      EXCEPT
      SELECT 2 AS x
      UNION
      SELECT 3 AS x
       GROUP BY CUBE ( x , x , x )
--     HAVING NOT - - ( EXISTS ( SELECT 1 ) ) = ANY ( NOT MAX ( x ) < AVG ( 'to' ) )
     )
----
False

